#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: gp {post|link} [--force]" >&2
    exit 64
}

FORCE=0
ACTION=""
for arg in "$@"; do
    case "$arg" in
        -f|--force) FORCE=1 ;;
        post|link) [ -z "$ACTION" ] && ACTION="$arg" || usage ;;
        *) usage ;;
    esac
done

[ -n "$ACTION" ] || usage

case "$ACTION" in
    post) CMD="graphein:post" ;;
    link) CMD="graphein:link" ;;
esac

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

PROJECT_ROOT="$SCRIPT_DIR"
while [ "$PROJECT_ROOT" != "/" ] && [ ! -f "$PROJECT_ROOT/artisan" ]; do
    PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
done

if [ ! -f "$PROJECT_ROOT/artisan" ]; then
    echo "gp: could not locate Laravel project root (no artisan file found)" >&2
    exit 1
fi

cd "$PROJECT_ROOT"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "gp: $PROJECT_ROOT is not a git repository" >&2
    exit 1
fi

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [ "$BRANCH" != "main" ]; then
    echo "gp: must be on 'main' branch (currently on '$BRANCH')" >&2
    exit 1
fi

if [ "$FORCE" -eq 0 ]; then
    if ! git diff --quiet --ignore-submodules || ! git diff --cached --quiet --ignore-submodules; then
        echo "gp: you have uncommitted changes — commit, stash, or pass --force to override" >&2
        exit 1
    fi

    if [ -n "$(git ls-files --others --exclude-standard)" ]; then
        echo "gp: you have untracked files — commit, stash, or pass --force to override" >&2
        exit 1
    fi
fi

exec php artisan "$CMD"
